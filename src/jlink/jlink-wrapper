#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${REAL_JLINK:-}" ]]; then
  jlink_bin="$REAL_JLINK"
elif [[ -n "${JAVA_HOME:-}" && -x "$JAVA_HOME/bin/jlink" ]]; then
  jlink_bin="$JAVA_HOME/bin/jlink"
else
  jlink_bin="$(command -v jlink)"
fi

args=()
output_dir=""
while (($#)); do
  case "$1" in
    --compress)
      shift
      if [[ "${1:-}" == "2" ]]; then
        args+=("--compress" "zip-6")
      else
        args+=("--compress" "${1:-}")
      fi
      ;;
    --compress=2)
      args+=("--compress=zip-6")
      ;;
    --output)
      args+=("--output" "$2")
      output_dir="$2"
      shift
      ;;
    --output=*)
      args+=("$1")
      output_dir="${1#--output=}"
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift
done

"$jlink_bin" "${args[@]}"

if [[ -n "$output_dir" ]]; then
  rm -f "$output_dir/bin/keytool"
fi
